<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/background_light"
    android:padding="@dimen/_16dp"
    android:foreground="?attr/selectableItemBackground">
    <ImageView
        android:id="@+id/articleImage"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:background="@color/edit_text_light"/>
    <TextView
        android:id="@+id/articleSourceText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:textColor="@color/accent_light"
        style="@style/TextAppearance.App.Title"
        tools:text="ROITERS"
        android:textSize="10sp"
        app:layout_constraintTop_toTopOf="@id/articleImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/articleImage"
        app:layout_constraintHorizontal_bias="0.0"/>
    <TextView
        android:id="@+id/articleTitleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        style="@style/TextAppearance.App.Title"
        tools:text="The Future of Renewable Energy in 2026"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/articleImage"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintTop_toBottomOf="@id/articleSourceText" />
    <TextView
        android:id="@+id/articleOverviewText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:maxLines="2"
        android:ellipsize="end"
        style="@style/TextAppearance.App.Subtitle"
        tools:text="Exploring the latest breakthroughs in solar and wind technology across…"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/articleImage"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintTop_toBottomOf="@id/articleTitleText"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remove"
        android:textSize="12sp"
        android:textColor="@color/accent_light"
        android:drawableStart="@drawable/baseline_bookmark_remove_24"
        android:drawablePadding="1dp"
        android:drawableTint="@color/accent_light"
        android:gravity="center"
        android:background="@drawable/button_background"
        android:layout_marginTop="8dp"
        android:foreground="?attr/selectableItemBackground"
        style="@style/TextAppearance.App.Title"
        app:layout_constraintTop_toBottomOf="@id/articleOverviewText"
        android:clickable="true"/>


</androidx.constraintlayout.widget.ConstraintLayout>