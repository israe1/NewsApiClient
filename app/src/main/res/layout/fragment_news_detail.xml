<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/background_light"
    tools:context=".NewsDetailFragment">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/newsDetailToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:navigationIcon="@drawable/outline_arrow_back_24"
        tools:title="The Boston Globe"
        app:menu="@menu/news_detail_menu"
        app:titleTextAppearance="@style/TextAppearance.App.Title"/>
    <View
        android:id="@+id/toolbarDivider"
        app:layout_constraintTop_toBottomOf="@id/newsDetailToolbar"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/edit_text_light"/>
    <WebView
        android:id="@+id/newsDetailWebView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarDivider"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/saveArticleFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/_16dp"
        android:src="@drawable/outline_bookmark_24"
        android:text="@string/save_article"
        android:textColor="@color/background_light"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.CircularFAB"
        app:backgroundTint="@color/accent_light"
        app:icon="@drawable/outline_bookmark_24"
        app:iconTint="@color/background_light"
        app:elevation="@dimen/_16dp"
        android:visibility="gone"/>
</androidx.constraintlayout.widget.ConstraintLayout>